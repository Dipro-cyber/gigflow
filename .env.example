# Root .env.example — copy to .env and fill in values
# This file is safe to commit — never commit the actual .env

# Backend
NODE_ENV=production
PORT=5000
MONGO_URI=mongodb://mongo:27017/gigflow
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:3000

# Frontend (Vite)
VITE_API_URL=http://localhost:5000
